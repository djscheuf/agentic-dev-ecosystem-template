              "root",
              "description",
              "tech_stack"
            ]
          },
          "examples": [
            [
              {
                "root": "path/to/subproject/root",
                "description": "Description of the subproject and it's propose",
                "tech_stack": {
                  "programming_language": "Python",
                  "frameworks": [],
                  "libraries": [],
                  "unit_testing_tools": []
