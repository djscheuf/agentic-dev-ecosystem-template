        "description": {
          "type": "string",
          "description": "Description",
          "examples": [
            "Description of the project structure and purpose"
          ]
        },
        "tech_stack": {
          "type": "object",
          "description": "Tech stack",
          "properties": {
            "programming_languages": {
              "type": "array",
              "description": "Programming languages",
              "items": {
                "type": "string"
              },
              "examples": [
                [
                  "Python",
                  "typescript"
                ]
              ]
            },
            "frameworks": {
              "type": "array",
              "description": "Frameworks",
              "examples": [
                []
              ]
            },
            "libraries": {
              "type": "array",
              "description": "Libraries",
              "examples": [
                []
              ]
