            "programming_languages",
            "frameworks",
            "libraries",
            "unit_testing_tools"
          ],
          "examples": [
            {
              "programming_languages": [
                "Python",
                "typescript"
              ],
              "frameworks": [],
              "libraries": [],
              "unit_testing_tools": []
            }
          ]
        },
